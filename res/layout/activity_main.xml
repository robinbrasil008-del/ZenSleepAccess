<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0B1220"
    android:orientation="vertical">

    <!-- CONTEÚDO -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="22dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🌙 ZenSleep"
                android:textColor="#FFFFFF"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="18dp"
                android:text="Relaxe sua mente e durma melhor"
                android:textColor="#9AA4B2"
                android:textSize="14sp" />

            <!-- BOTÃO TIMER (VISUAL IGUAL AO MODELO) -->
            <LinearLayout
                android:id="@+id/btnTimer"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="18dp"
                android:background="@drawable/pill_button"
                android:gravity="center"
                android:paddingLeft="18dp"
                android:paddingRight="18dp"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⏱  Definir Timer"
                    android:textColor="#E8ECF2"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- GRID 2 COLUNAS -->
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:useDefaultMargins="false">

                <!-- CARD 1 -->
                <include
                    layout="@layout/item_sound_card"
                    android:id="@+id/includeChuva"
                    android:layout_width="0dp"
                    android:layout_height="190dp"
                    android:layout_margin="10dp"
                    android:layout_columnWeight="1" />

                <!-- CARD 2 -->
                <include
                    layout="@layout/item_sound_card"
                    android:id="@+id/includeMar"
                    android:layout_width="0dp"
                    android:layout_height="190dp"
                    android:layout_margin="10dp"
                    android:layout_columnWeight="1" />

                <!-- CARD 3 -->
                <include
                    layout="@layout/item_sound_card"
                    android:id="@+id/includeFloresta"
                    android:layout_width="0dp"
                    android:layout_height="190dp"
                    android:layout_margin="10dp"
                    android:layout_columnWeight="1" />

            </GridLayout>

        </LinearLayout>
    </ScrollView>

    <!-- BARRA INFERIOR -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="#0B1220"
        android:orientation="horizontal"
        android:gravity="center">

        <TextView
            android:id="@+id/navInicio"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="🏠\nInício"
            android:textColor="#00D1B2"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/navFav"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="❤\nFavoritos"
            android:textColor="#9AA4B2"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/navAjustes"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="⚙\nAjustes"
            android:textColor="#9AA4B2"
            android:textSize="12sp" />
    </LinearLayout>

</LinearLayout>
