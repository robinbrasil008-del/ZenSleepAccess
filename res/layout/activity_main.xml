<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="#0B1220"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- HEADER -->
    <LinearLayout
        android:orientation="vertical"
        android:padding="24dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:text="🌙 ZenSleep"
            android:textColor="#FFFFFF"
            android:textSize="26sp"
            android:textStyle="bold"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:text="Relaxe sua mente e durma melhor"
            android:textColor="#9AA4B2"
            android:textSize="14sp"
            android:layout_marginTop="4dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <Button
            android:id="@+id/btnTimer"
            android:text="⏱ Definir Timer"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:backgroundTint="#1F2937"
            android:layout_marginTop="16dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

    </LinearLayout>

    <!-- GRID -->
    <GridLayout
        android:id="@+id/gridSounds"
        android:columnCount="2"
        android:padding="16dp"
        android:useDefaultMargins="true"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- CARD 1 -->
        <LinearLayout
            android:id="@+id/cardChuva"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="20dp"
            android:background="#141C2F"
            android:layout_width="0dp"
            android:layout_height="180dp"
            android:layout_columnWeight="1">

            <TextView
                android:text="🌧"
                android:textSize="42sp"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="10dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:text="Chuva"
                android:textSize="16sp"
                android:textColor="#FFFFFF"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- CARD 2 -->
        <LinearLayout
            android:id="@+id/cardMar"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="20dp"
            android:background="#141C2F"
            android:layout_width="0dp"
            android:layout_height="180dp"
            android:layout_columnWeight="1">

            <TextView
                android:text="🌊"
                android:textSize="42sp"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="10dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:text="Ondas do Mar"
                android:textSize="16sp"
                android:textColor="#FFFFFF"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- CARD 3 -->
        <LinearLayout
            android:id="@+id/cardFloresta"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="20dp"
            android:background="#141C2F"
            android:layout_width="0dp"
            android:layout_height="180dp"
            android:layout_columnWeight="1">

            <TextView
                android:text="🌲"
                android:textSize="42sp"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="10dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:text="Floresta"
                android:textSize="16sp"
                android:textColor="#FFFFFF"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

    </GridLayout>

    <!-- BOTTOM NAV -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#111827"
        app:itemIconTint="#4FD1C5"
        app:itemTextColor="#4FD1C5"
        app:menu="@menu/bottom_menu" />

</LinearLayout>
