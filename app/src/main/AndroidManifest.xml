<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- ✅ Necessário para alarmes exatos no Android 12+ -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM"/>

    <application
        android:allowBackup="true"
        android:label="ZenSleep"
        android:theme="@style/Theme.ZenSleep"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true">

        <!-- Tela Principal -->
        <activity
            android:name=".MainActivity"
            android:exported="true">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

        </activity>

        <!-- 🔔 Tela de Configuração do Despertador -->
        <activity
            android:name=".AlarmActivity"
            android:exported="false"
            android:label="Despertador" />

        <!-- 🔊 Tela que toca quando o alarme dispara -->
        <activity
            android:name=".AlarmRingingActivity"
            android:exported="false"
            android:showWhenLocked="true"
            android:turnScreenOn="true"
            android:excludeFromRecents="true"
            android:label="Alarme" />

        <!-- 📡 Receiver que dispara o alarme -->
        <receiver
            android:name=".AlarmReceiver"
            android:exported="false" />

        <!-- 🔐 Tela de Política de Privacidade -->
        <activity
            android:name=".PrivacyPolicyActivity"
            android:exported="false"
            android:label="Política de Privacidade" />

    </application>

</manifest>
