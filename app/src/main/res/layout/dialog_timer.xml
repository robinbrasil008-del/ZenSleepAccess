<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:padding="20dp"
    android:orientation="vertical"
    android:background="@drawable/bg_dialog_premium"
    android:elevation="16dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <!-- 🔥 CARD DESPERTADOR MELHORADO -->
    <LinearLayout
        android:id="@+id/cardTimerAlarm"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bg_card_glass"
        android:padding="16dp"
        android:layout_marginBottom="18dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackground">

        <LinearLayout
            android:orientation="vertical"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content">

            <TextView
                android:text="⏰ Despertador"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="16sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:text="Tocar alarme quando o tempo terminar"
                android:textColor="#94A3B8"
                android:textSize="13sp"
                android:layout_marginTop="4dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <Switch
            android:id="@+id/switchTimerAlarm"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </LinearLayout>

    <!-- TÍTULO TIMER -->
    <TextView
        android:text="Definir tempo (minutos)"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:layout_gravity="center"
        android:layout_marginBottom="12dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <!-- INPUT -->
    <LinearLayout
    android:layout_width="220dp"
    android:layout_height="50dp"
    android:background="@drawable/bg_input"
    android:orientation="horizontal"
    android:layout_gravity="center"
    android:padding="14dp"
    android:layout_marginBottom="6dp">

    <ImageView
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:src="@android:drawable/ic_menu_recent_history"
        android:tint="#A855F7"/>

    <EditText
        android:id="@+id/inputMinutes"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Ex: 30"
        android:textColor="#FFFFFF"
        android:textColorHint="#66FFFFFF"
        android:background="@android:color/transparent"
        android:inputType="number"
        android:textSize="16sp"
        android:paddingStart="10dp"/>
</LinearLayout>

    <!-- BOTÃO -->
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnStartTimer"
        android:text="INICIAR TEMPO"
        android:textColor="#FFFFFF"
        android:background="@drawable/bg_button_gradient"
        android:backgroundTint="@null"
        android:layout_marginTop="16dp"
        android:layout_width="180dp"
        android:layout_gravity="center"
        android:layout_height="48dp"/>

</LinearLayout>
