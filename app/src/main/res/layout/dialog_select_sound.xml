<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@drawable/bg_dialog_premium">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Selecionar Som"
        android:fontFamily="@font/playfair"
        android:textColor="#E6DAB3"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="20dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <TextView
            android:id="@+id/optionSound1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Som Padrão 1"
            android:fontFamily="@font/playfair"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="16sp"
            android:paddingVertical="12dp"
            android:paddingHorizontal="8dp"
            android:background="?attr/selectableItemBackground"/>

        <ImageView
            android:id="@+id/btnPlaySound1"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:padding="12dp"
            android:src="@drawable/ic_media_play"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <TextView
            android:id="@+id/optionSound2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Som Padrão 2"
            android:fontFamily="@font/playfair"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="16sp"
            android:paddingVertical="12dp"
            android:paddingHorizontal="8dp"
            android:background="?attr/selectableItemBackground"/>

        <ImageView
            android:id="@+id/btnPlaySound2"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:padding="12dp"
            android:src="@drawable/ic_media_play"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp">

        <TextView
            android:id="@+id/optionSound3"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Som Padrão 3"
            android:fontFamily="@font/playfair"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="16sp"
            android:paddingVertical="12dp"
            android:paddingHorizontal="8dp"
            android:background="?attr/selectableItemBackground"/>

        <ImageView
            android:id="@+id/btnPlaySound3"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:padding="12dp"
            android:src="@drawable/ic_media_play"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"/>
    </LinearLayout>

    <TextView
        android:id="@+id/optionUpload"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="📁 Escolher Audio do Dispositivo"
        android:fontFamily="@font/playfair"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:textSize="16sp"
        android:paddingVertical="12dp"
        android:paddingHorizontal="8dp"
        android:background="?attr/selectableItemBackground"/>

</LinearLayout>
