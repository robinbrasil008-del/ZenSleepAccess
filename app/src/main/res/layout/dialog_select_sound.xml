<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="300dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@drawable/bg_dialog_premium">

    <LinearLayout

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Selecionar Som"
        android:fontFamily="@font/playfair"
        android:textColor="#E6DAB3"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="20dp">

    <TextView
        android:id="@+id/optionSound1"
        android:text="Som Padrão 1"
        android:fontFamily="@font/playfair"
        android:textColor="#F0EACF"
        android:textSize="16sp"
        android:padding="12dp">

    <TextView
        android:id="@+id/optionSound2"
        android:text="Som Padrão 2"
        android:fontFamily="@font/playfair"
        android:textColor="#F0EACF"
        android:textSize="16sp"
        android:padding="12dp">

    <TextView
        android:id="@+id/optionSound3"
        android:text="Som Padrão 3"
        android:fontFamily="@font/playfair"
        android:textColor="#F0EACF"
        android:textSize="16sp"
        android:padding="12dp">

    <TextView
        android:id="@+id/optionUpload"
        android:text="📁 Escolher Audio do Dispositivo"
        android:fontFamily="@font/playfair"
        android:textColor="#F0EACF"
        android:textSize="16sp"
        android:padding="12dp"/>
</LinearLayout>
</LinearLayout>
