                        android:max="100"
                        android:progress="80"/>
                </LinearLayout>

            </FrameLayout>

            <!-- ✅ NOITE COM GRILOS -->
            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="190dp"
                android:layout_margin="8dp"
                android:layout_columnWeight="1"
