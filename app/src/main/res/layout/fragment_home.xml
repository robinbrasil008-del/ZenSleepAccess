<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:ads="http://schemas.android.com/apk/res-auto"
    android:background="?android:colorBackground"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:padding="24dp"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <com.google.android.gms.ads.AdView
    android:id="@+id/adView"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    ads:adSize="BANNER"
    ads:adUnitId="ca-app-pub-8296610548842772/7784029047"/>

        <!-- TÍTULO -->
        <ImageView
    android:layout_width="310dp"
    android:layout_height="160dp"
    android:src="@drawable/logo_zensleep"
    android:layout_marginTop="10dp"
    android:layout_marginBottom="6dp"
    android:layout_gravity="center"
    android:adjustViewBounds="true"/>
            
        <!-- 🔥 NOVO RELÓGIO ESTILIZADO -->
          <com.zensleep.AnimatedTimerCardLayout
           android:id="@+id/timerCard"
           android:layout_width="200dp"
           android:layout_height="55dp"
           android:layout_marginBottom="6dp"
           android:layout_marginTop="6dp"
           android:gravity="center"
           android:orientation="horizontal"
           android:padding="7dp">

       <ImageView
           android:id="@+id/timerIcon"
           android:layout_width="34dp"
           android:layout_height="34dp"
           android:translationX="6dp"
           android:scaleType="fitCenter"
           android:src="@drawable/hourglass_static"/>
              
    <TextView
    android:id="@+id/txtTimer"
    android:text="00:00"
    android:textSize="32sp"
    android:gravity="center"
    android:textColor="#AB47BC"
    android:layout_width="120dp"
    android:layout_height="65dp"/>
              
</com.zensleep.AnimatedTimerCardLayout>

    <FrameLayout
            android:layout_width="170dp"
            android:layout_height="48dp">

    <!-- 🔥 BORDA NEON -->
        <com.zensleep.NeonBorderView
            android:id="@+id/neonBorder"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>

        <!-- BOTÃO TIMER -->
        <Button
            android:id="@+id/btnTimer"
            android:textColor="@android:color/white"
            android:layout_width="170dp"
            android:layout_height="48dp"
            android:layout_marginTop="6dp"
            android:background="@android:color/transparent"/>

    </FrameLayout>
        
        <!-- GRID -->
        <GridLayout
            android:columnCount="2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- CARD CHUVA -->
            <FrameLayout
    android:id="@+id/cardChuva"
    android:layout_width="0dp"
    android:layout_height="190dp"
    android:layout_margin="8dp"
    android:layout_columnWeight="1"
    android:background="@drawable/bg_card"
    android:clipToOutline="true"
    android:elevation="6dp"
    android:foreground="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true">

    <!-- 🖼 IMAGEM DE FUNDO -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/bg_chuva"
        android:scaleType="centerCrop"/>

    <!-- 🌑 OVERLAY ESCURO -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#AA0B1220"/>

    <!-- ⭐ FAVORITO -->
    <ImageView
        android:id="@+id/starChuva"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_gravity="end|top"
        android:layout_margin="10dp"
        android:src="@android:drawable/btn_star_big_off"
        android:tint="@android:color/white"/>

    <!-- 📦 CONTEÚDO -->
    <FrameLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="center"
        android:padding="16dp">

        <TextView
            android:text="Chuva"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_gravity="top|center_horizontal"
            android:layout_marginTop="16dp"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>

        <ImageView
            android:id="@+id/btnPlayChuva"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_gravity="center"
            android:background="@drawable/bg_play_circle"
            android:padding="12dp"
            android:src="@android:drawable/ic_media_play"
            android:tint="@android:color/white"
            android:contentDescription="Tocar ou pausar Chuva"/>

        <SeekBar
            android:id="@+id/seekChuva"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:visibility="gone"
            android:alpha="0.9"
            android:max="100"
            android:progress="80"/>

         </FrameLayout>

   </FrameLayout>

