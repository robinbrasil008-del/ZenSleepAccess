<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="#0f172a"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:id="@+id/btnBack"
        android:layout_width="50dp"
        android:layout_height="40dp"
        android:layout_marginTop="16dp"
        android:layout_marginStart="16dp"
        android:src="@drawable/ic_seta_voltar"
        android:contentDescription="Voltar"
        android:clickable="true"
        android:focusable="true"
        android:padding="4dp"
        android:background="?android:attr/selectableItemBackgroundBorderless"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="20dp"
        android:scrollbars="none">

        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="40dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Política de Privacidade"
                android:textColor="#38bdf8"
                android:textSize="28sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Aplicativo Mobile ZenSleep\nÚltima atualização: Março de 2026"
                android:textColor="#94a3b8"
                android:textSize="14sp"
                android:gravity="center"
                android:lineSpacingExtra="4dp"
                android:layout_marginBottom="40dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="1. Introdução"
                android:textColor="#38bdf8"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="O ZenSleep (&#34;nós&#34; ou &#34;nosso&#34;) valoriza sua privacidade. Esta Política de Privacidade explica como as informações são tratadas quando você usa o aplicativo móvel ZenSleep (o &#34;App&#34;).\n\nAo usar o App, você concorda com as práticas descritas nesta Política de Privacidade."
                android:textColor="#f1f5f9"
                android:textSize="15sp"
                android:lineSpacingExtra="6dp"
                android:layout_marginBottom="32dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="2. Informações que Coletamos"
                android:textColor="#38bdf8"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="O ZenSleep não coleta diretamente informações de identificação pessoal. No entanto, certos dados podem ser coletados automaticamente por meio de serviços de terceiros integrados ao App:\n\n• Tipo de dispositivo e sistema operacional\n• Endereço IP\n• Identificadores de publicidade (como o ID de Publicidade do Google)\n• Estatísticas de uso do App\n• Relatórios de falhas e diagnósticos de desempenho\n\nEssas informações são usadas exclusivamente para melhorar a experiência do usuário, manter a funcionalidade do aplicativo e veicular anúncios relevantes."
                android:textColor="#f1f5f9"
                android:textSize="15sp"
                android:lineSpacingExtra="6dp"
                android:layout_marginBottom="32dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="3. Publicidade e Serviços de Terceiros"
                android:textColor="#38bdf8"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="O ZenSleep usa o Google AdMob para exibir anúncios. O AdMob pode coletar e processar dados de acordo com suas próprias políticas de privacidade.\n\nPara mais informações, consulte a Política de Privacidade do Google:\nhttps://policies.google.com/privacy\n\nUsuários localizados no Espaço Econômico Europeu (EEE), Reino Unido ou Califórnia podem receber opções de consentimento em relação à publicidade personalizada em conformidade com as leis aplicáveis (GDPR e CCPA)."
                android:textColor="#f1f5f9"
                android:textSize="15sp"
                android:lineSpacingExtra="6dp"
                android:autoLink="web"
                android:textColorLink="#38bdf8"
                android:layout_marginBottom="32dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="4. Uso de Dados"
                android:textColor="#38bdf8"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Qualquer dado coletado por meio de serviços de terceiros é usado para:\n\n• Exibir anúncios\n• Analisar o desempenho do aplicativo\n• Melhorar a estabilidade e a experiência do usuário\n• Detectar e prevenir fraudes ou abusos"
                android:textColor="#f1f5f9"
                android:textSize="15sp"
                android:lineSpacingExtra="6dp"
                android:layout_marginBottom="32dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="5. Segurança de Dados"
                android:textColor="#38bdf8"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Implementamos salvaguardas comercialmente razoáveis para proteger as informações processadas no App. No entanto, nenhum método de transmissão ou armazenamento eletrônico é 100% seguro, e a segurança absoluta não pode ser garantida."
                android:textColor="#f1f5f9"
                android:textSize="15sp"
                android:lineSpacingExtra="6dp"
                android:layout_marginBottom="32dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="6. Privacidade das Crianças"
                android:textColor="#38bdf8"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="O ZenSleep não é destinado a crianças menores de 13 anos. Não coletamos intencionalmente informações pessoais de crianças. Se você acredita que uma criança forneceu informações, entre em contato conosco para que as medidas adequadas possam ser tomadas."
                android:textColor="#f1f5f9"
                android:textSize="15sp"
                android:lineSpacingExtra="6dp"
                android:layout_marginBottom="32dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="7. Seus Direitos"
                android:textColor="#38bdf8"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Dependendo da sua localização, você pode ter direitos de acordo com as leis de privacidade aplicáveis, incluindo o direito de solicitar acesso, correção ou exclusão de certos dados pessoais coletados por serviços de terceiros. Entre em contato conosco para obter assistência."
                android:textColor="#f1f5f9"
                android:textSize="15sp"
                android:lineSpacingExtra="6dp"
                android:layout_marginBottom="32dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="8. Alterações a Esta Política"
                android:textColor="#38bdf8"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Podemos atualizar esta Política de Privacidade de tempos em tempos. As atualizações serão publicadas nesta página com uma data de &#34;Última atualização&#34; revisada."
                android:textColor="#f1f5f9"
                android:textSize="15sp"
                android:lineSpacingExtra="6dp"
                android:layout_marginBottom="32dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="9. Informações de Contato"
                android:textColor="#38bdf8"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Se você tiver alguma dúvida sobre esta Política de Privacidade, pode nos contatar:\n\nE-mail: luxecharms1.0@gmail.com\nSite: https://app-zensleep.site"
                android:textColor="#f1f5f9"
                android:textSize="15sp"
                android:lineSpacingExtra="6dp"
                android:autoLink="web|email"
                android:textColorLink="#38bdf8"
                android:layout_marginBottom="50dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="© 2026 ZenSleep. Todos os direitos reservados."
                android:textColor="#94a3b8"
                android:textSize="13sp"
                android:gravity="center"
                android:layout_marginBottom="20dp"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
