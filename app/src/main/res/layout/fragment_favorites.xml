<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="@drawable/bg_screen_gradient"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:padding="24dp"
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- TÍTULO -->
        <TextView
            android:text="Sons Favoritos ❤️"
            android:fontFamily="@font/playfair"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_gravity="center"
            android:textColor="#E6DAB3"
            android:layout_marginBottom="24dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <!-- 🔥 AQUI ENTRA OS CARDS DO HOME -->
        <include
            layout="@layout/favorites_cards"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <!-- TEXTO VAZIO -->
        <TextView
            android:id="@+id/emptyText"
            android:text="Nenhum favorito ainda 😴"
            android:textColor="?android:textColorSecondary"
            android:textSize="16sp"
            android:gravity="center"
            android:layout_marginTop="40dp"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

    </LinearLayout>

</ScrollView>
