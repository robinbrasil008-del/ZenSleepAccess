<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="#0D1B2A"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Conteúdo principal -->
    <ScrollView
        android:layout_weight="1"
        android:layout_width="match_parent"
        android:layout_height="0dp">

        <LinearLayout
            android:padding="24dp"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- Título -->
            <TextView
                android:text="🌙 ZenSleep"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="6dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:text="Relaxe sua mente e durma melhor"
                android:textSize="16sp"
                android:textColor="#9AA4B2"
                android:layout_marginBottom="24dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <!-- Botão Timer -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTimer"
                android:text="⏱ DEFINIR TIMER"
                android:layout_gravity="center"
                android:backgroundTint="#1B263B"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="28dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <!-- GRID -->
            <GridLayout
                android:columnCount="2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <!-- CARD -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="240dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="10dp"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="10dp"
                    app:cardBackgroundColor="#1B263B">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <!-- Favorito -->
                        <ImageView
                            android:id="@+id/favChuva"
                            android:src="@android:drawable/btn_star_big_off"
                            android:layout_margin="12dp"
                            android:layout_gravity="end|top"
                            android:layout_width="24dp"
                            android:layout_height="24dp"/>

                        <!-- Conteúdo -->
                        <LinearLayout
                            android:gravity="center"
                            android:orientation="vertical"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent">

                            <TextView
                                android:text="🌧"
                                android:textSize="40sp"
                                android:textColor="#FFFFFF"
                                android:layout_marginBottom="8dp"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"/>

                            <TextView
                                android:text="Chuva"
                                android:textSize="18sp"
                                android:textColor="#FFFFFF"
                                android:layout_marginBottom="14dp"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"/>

                            <ImageButton
                                android:id="@+id/playChuva"
                                android:background="@android:drawable/btn_default"
                                android:src="@android:drawable/ic_media_play"
                                android:layout_width="56dp"
                                android:layout_height="56dp"/>

                        </LinearLayout>

                    </FrameLayout>

                </androidx.cardview.widget.CardView>

                <!-- CARD 2 -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="240dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="10dp"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="10dp"
                    app:cardBackgroundColor="#1B263B">

                    <LinearLayout
                        android:gravity="center"
                        android:orientation="vertical"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <TextView
                            android:text="🌊"
                            android:textSize="40sp"
                            android:textColor="#FFFFFF"
                            android:layout_marginBottom="8dp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>

                        <TextView
                            android:text="Ondas do Mar"
                            android:textSize="18sp"
                            android:textColor="#FFFFFF"
                            android:layout_marginBottom="14dp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>

                        <ImageButton
                            android:id="@+id/playMar"
                            android:background="@android:drawable/btn_default"
                            android:src="@android:drawable/ic_media_play"
                            android:layout_width="56dp"
                            android:layout_height="56dp"/>

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

            </GridLayout>

        </LinearLayout>

    </ScrollView>

    <!-- Bottom Navigation -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:background="#1B263B"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:itemIconTint="#FFFFFF"
        app:itemTextColor="#FFFFFF"
        app:menu="@menu/bottom_menu"/>

</LinearLayout>
