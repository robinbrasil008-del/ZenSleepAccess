<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen_gradient"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="32dp"
        android:paddingBottom="40dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:layout_marginBottom="40dp">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_seta_voltar"
                android:contentDescription="Voltar"
                android:clickable="true"
                android:focusable="true"
                android:padding="4dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Configurar Despertador"
                android:textSize="26sp"
                android:fontFamily="@font/playfair"
                android:textColor="#E6DAB3"
                android:layout_marginStart="16dp"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/cardAlarmSound"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card_glass"
            android:padding="24dp"
            android:layout_marginBottom="16dp"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?android:attr/selectableItemBackground">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SELECIONAR SOM"
                android:textColor="#E6DAB3"
                android:textSize="12sp"
                android:letterSpacing="0.08"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="14dp">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_nota_musical"
                    android:layout_marginEnd="12dp" />

                <TextView
                    android:id="@+id/txtAlarmSound"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="Som 1\nDuração: 30s"
                    android:textColor="#F8FAFC"
                    android:textSize="18sp"
                    android:lineSpacingExtra="4dp"/>

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    app:srcCompat="@drawable/ic_seta_baixo"
                    app:tint="#4AD3C6"/>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card_glass"
            android:padding="24dp"
            android:layout_marginBottom="16dp"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="VOLUME DO ALARME"
                    android:textColor="#E6DAB3"
                    android:textSize="12sp"
                    android:letterSpacing="0.08"/>

                <TextView
                    android:id="@+id/txtAlarmVolumeValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="80%"
                    android:textColor="#4AD3C6"
                    android:textSize="16sp"/>
            </LinearLayout>

            <SeekBar
                android:id="@+id/seekAlarmVolume"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:paddingStart="0dp"
                android:paddingEnd="0dp"
                android:progressTint="#4AD3C6"
                android:thumbTint="#4AD3C6"
                android:max="100"
                android:progress="80"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card_glass"
            android:paddingHorizontal="24dp"
            android:paddingVertical="18dp"
            android:layout_marginBottom="16dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="ATIVAR VIBRAÇÃO"
                android:textColor="#E6DAB3"
                android:textSize="15sp"
                android:drawableStart="@drawable/ic_vibracao"
                android:drawablePadding="12dp"
                android:gravity="center_vertical"/>

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switchVibrate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:thumbTint="#4AD3C6"
                app:trackTint="#1E293B"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card_glass"
            android:padding="24dp"
            android:layout_marginBottom="40dp"
            android:orientation="vertical"
            android:clickable="false"
            android:focusable="false">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MODO SONECA"
                android:textColor="#E6DAB3"
                android:textSize="14sp"
                android:drawableStart="@drawable/ic_lua"
                android:drawablePadding="12dp"
                android:gravity="center_vertical"
                android:letterSpacing="0.08"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Disponível em breve"
                android:textColor="#94A3B8"
                android:textSize="16sp"
                android:layout_marginTop="16dp"/>

            <TextView
                android:id="@+id/txtSnoozeValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Intervalo: 5 minutos"
                android:textColor="#94A3B8"
                android:textSize="14sp"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <Button
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="SALVAR"
            android:textSize="18sp"
            android:fontFamily="@font/playfair"
            android:letterSpacing="0.1"
            android:textColor="#E6DAB3"
            android:background="@drawable/bg_button_gradient"/>
    </LinearLayout>
</ScrollView>

